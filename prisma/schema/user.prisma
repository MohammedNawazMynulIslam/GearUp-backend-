model User {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  password      String
  phone         String?
  address       String?
  role          Role
  isSuspended   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  gearItems      Gear[]
  rentalOrders   RentalOrder[]
  reviews        Review[]
  @@index([role])
  
}

enum Role {
  ADMIN
  PROVIDER
  CUSTOMER
}